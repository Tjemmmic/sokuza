# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_TOKEN=ghp_your_personal_access_token

# ─── Slack ───────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# ─── AI Providers ──────────────────────────────────────────────────────────
# Each provider is declared in `sokuza.config.yaml` under `ai.providers`
# and referenced by name from workflows. The env vars below feed into
# that config via ${VAR_NAME} interpolation.

# Anthropic direct API
# ANTHROPIC_API_KEY=sk-ant-your-api-key

# Claude Code CLI (no key needed — just `claude` on PATH and authenticated)

# ZAI GLM — works for both the `zai-glm` (API) and `zai-glm-agent`
# (Claude Code CLI pointed at ZAI's Anthropic-compatible endpoint)
# providers declared in sokuza.config.yaml.
# ZAI_API_KEY=your-zai-api-key

# Opencode CLI uses its own config (no env var needed here) — just have
# `opencode` on PATH with your providers configured in opencode itself.
