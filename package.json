{
  "name": "sokuza",
  "version": "0.1.0",
  "description": "Hook-driven AI workflow automation engine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sokuza": "dist/index.js"
  },
  "files": [
    "dist",
    "dashboard",
    "templates",
    "sokuza.config.example.yaml",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "automation",
    "workflow",
    "github",
    "webhooks",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "js-yaml": "^4.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
