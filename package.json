{
  "name": "sokuza",
  "version": "0.2.6",
  "description": "Hook-driven AI workflow automation engine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sokuza": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "dashboard",
    "templates",
    "sokuza.config.example.yaml",
    "sokuza.env.example",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check-changelog": "node scripts/check-changelog.mjs",
    "prepublishOnly": "npm run lint && npm test && npm run check-changelog && npm run build"
  },
  "keywords": [
    "automation",
    "workflow",
    "github",
    "webhooks",
    "ai"
  ],
  "license": "MIT",
  "author": "Donovan Tjemmes <mdtjemmes@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tjemmmic/sokuza.git"
  },
  "homepage": "https://sokuza.ai",
  "bugs": {
    "url": "https://github.com/Tjemmmic/sokuza/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
