# Sokuza environment variables
#
# sokuza.config.yaml interpolates ${VAR_NAME} tokens with values from this
# file (and from your shell environment). Uncomment only the ones you use
# — unused ones can stay commented out safely.
#
# Never commit your real .env file. It should already be in .gitignore.

# ─── Anthropic API ──────────────────────────────────────────
# Required only if any workflow specifies provider: anthropic.
# Leave unset to fall back to the Claude Code CLI on your PATH.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GitHub ─────────────────────────────────────────────────
# Personal access token. `repo` scope is enough for private repos; public
# repos only need the default scopes.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret configured in the GitHub webhook settings. Set this if you
# use the `github` integration (pushes, PR events, issue events). The
# `github-poll` and `gh-cli` integrations don't need it.
# GITHUB_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ─── Slack (optional) ──────────────────────────────────────
# Bot token from your Slack app's OAuth & Permissions page.
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret from the Slack app's Basic Information page; used to
# verify inbound events and slash commands.
# SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Custom webhooks (optional) ────────────────────────────
# Shared secret for endpoints defined under integrations.webhook.endpoints.
# One variable per endpoint name; match whatever the config interpolates.
# DEPLOY_HOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Z.AI GLM via Anthropic-compatible API (optional) ──────
# Only needed if your config references providers: zai-glm or zai-glm-agent.
# ZAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
